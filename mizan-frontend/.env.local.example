# Frontend environment variables template — copy to .env.local and fill in values
# IMPORTANT: use API origin only (no /api/v1 suffix). The frontend appends /api/v1 internally.

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_AI_VOICE_VOLUME=1
NEXT_PUBLIC_AI_VOICE_BOOST=1.8
