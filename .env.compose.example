# -------- Ports exposed on host --------
BACKEND_PORT=8000
FRONTEND_PORT=3000
FRONTEND_MOBILE_PORT=3001
POSTGRES_PORT_HOST=5432

# -------- Postgres (docker internal) --------
POSTGRES_DB=mizan
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# If true, Postgres imports /seed/${DB_SEED_FILE} ONLY on first initialization (empty volume).
DB_AUTO_SEED=true
DB_SEED_FILE=local.dump

# -------- SSL / Domain Configuration (Required for HTTPS) --------
DOMAIN=example.com
EMAIL=admin@example.com

# -------- Backend required/runtime settings --------
APP_ENV=production
SECRET_KEY=change-this-before-public-deploy
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional SMTP (OTP emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# AI / media providers
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
MISTRAL_STT_MODEL=voxtral-mini-latest
MISTRAL_STT_LANGUAGE=fr
MISTRAL_REALTIME_MODEL=voxtral-mini-transcribe-realtime-2602
MISTRAL_REALTIME_SAMPLE_RATE=16000
MISTRAL_REALTIME_TARGET_DELAY_MS=700
MISTRAL_REALTIME_SERVER_URL=wss://api.mistral.ai
MISTRAL_TTS_MODEL=voxtral-mini-tts-latest
MISTRAL_TTS_VOICE_ID=
MISTRAL_TTS_VOICE=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -------- Frontend public API origin --------
# IMPORTANT: API origin only (no /api/v1). Example on local machine:
# NEXT_PUBLIC_API_URL=http://localhost:8000
# For EC2/public server, set your public domain/IP origin:
# NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_AI_VOICE_VOLUME=1
NEXT_PUBLIC_AI_VOICE_BOOST=1.8
