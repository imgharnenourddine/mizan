FROM node:20-alpine

WORKDIR /app

ENV NEXT_TELEMETRY_DISABLED=1

ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ARG NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
ARG NEXT_PUBLIC_AI_VOICE_VOLUME=1
ARG NEXT_PUBLIC_AI_VOICE_BOOST=1.8

ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}
ENV NEXT_PUBLIC_WS_URL=${NEXT_PUBLIC_WS_URL}
ENV NEXT_PUBLIC_AI_VOICE_VOLUME=${NEXT_PUBLIC_AI_VOICE_VOLUME}
ENV NEXT_PUBLIC_AI_VOICE_BOOST=${NEXT_PUBLIC_AI_VOICE_BOOST}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

ENV NODE_ENV=production

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-H", "0.0.0.0", "-p", "3000"]
